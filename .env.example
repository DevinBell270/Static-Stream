YOUTUBE_API_KEY=your_api_key_here
REFRESH_INTERVAL_HOURS=24
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_password

# Skip calling YouTube on startup if database.json is newer than this many hours (default 6).
# Set to 0 to always refresh on startup — useful right after changing YOUTUBE_API_KEY.
# STARTUP_CACHE_MAX_AGE_HOURS=6
